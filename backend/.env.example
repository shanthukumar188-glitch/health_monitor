# ============================================================
# HEALTH MONITOR - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your credentials
# ============================================================

# Server
PORT=3001

# ─────────────────────────────────────────
# GROQ API KEY (Free at https://console.groq.com)
# Used for: AI chat, medical report analysis, skin analysis,
#           diet planner, exercise planner, medicine suggestions
# ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────
# TWILIO (Free trial at https://www.twilio.com)
# Used for: SMS alerts when sensor abnormalities detected
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
ALERT_PHONE_NUMBER=+91XXXXXXXXXX

# ─────────────────────────────────────────
# FRONTEND URL (for CORS)
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
